# ─────────── Supabase ───────────
# Live ChatQuest project: https://qucizmsdoswunfsnqjam.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://qucizmsdoswunfsnqjam.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection for Drizzle migrations + seed scripts.
# Live: postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# (Get the connection string from Project Settings → Database → Connection string.)
SUPABASE_DB_URL=

# ─────────── LLM ───────────
# Pick at least one. The provider is selected per chatbot node via the model picker.

# Anthropic Claude — used as primary by default.
ANTHROPIC_API_KEY=

# OpenAI — fallback for GPT models and (preferred) embeddings.
OPENAI_API_KEY=

# Google Gemini — alternate provider. Supports gemini-2.0-flash, gemini-1.5-pro, etc.
GEMINI_API_KEY=

# Embedding provider: "openai" (1536-dim, recommended) or "gemini" (768→1536 padded).
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# Default chat model when an instructor doesn't override.
DEFAULT_CHAT_MODEL=gemini-3-flash

# ─────────── Stripe (test mode) ───────────
# Phase 3 work — placeholders for now.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─────────── App ───────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email — Phase 1 logs invite links to the server console if RESEND_API_KEY is empty.
RESEND_API_KEY=
EMAIL_FROM="ChatQuest <noreply@chatquest.local>"
