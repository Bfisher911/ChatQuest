# ─────────── Supabase ───────────
# Live ChatQuest project: https://qucizmsdoswunfsnqjam.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://qucizmsdoswunfsnqjam.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Direct Postgres connection for Drizzle migrations + seed scripts.
# Live: postgres://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# (Get the connection string from Project Settings → Database → Connection string.)
SUPABASE_DB_URL=

# ─────────── LLM ───────────
# Gemini-only deployment. Get a key from https://aistudio.google.com/app/apikey
# (free tier is generous for development; paid tier unblocks higher quotas).
GEMINI_API_KEY=

# Embedding provider — Gemini's text-embedding-004 returns 768-dim vectors,
# padded to 1536 to match the pgvector column shape.
EMBEDDING_PROVIDER=gemini
EMBEDDING_MODEL=text-embedding-004

# Default chat model when an instructor doesn't override.
DEFAULT_CHAT_MODEL=gemini-3-flash-preview

# Anthropic + OpenAI keys are NOT required for this deployment. The provider
# abstraction in lib/llm/provider.ts supports them but the UI / generator
# pickers are restricted to Gemini, so leaving these blank is fine.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=

# ─────────── Stripe (test mode) ───────────
# Phase 3 work — placeholders for now.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─────────── App ───────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email — Phase 1 logs invite links to the server console if RESEND_API_KEY is empty.
RESEND_API_KEY=
EMAIL_FROM="ChatQuest <noreply@chatquest.local>"
